# Contentful credentials (required)
CONTENTFUL_SPACE_ID=
CONTENTFUL_MANAGEMENT_TOKEN=
CONTENTFUL_ENVIRONMENT=master

# Anthropic API key for Claude Vision (required)
ANTHROPIC_API_KEY=

# Watch directory — where your photo editor exports images
WATCH_DIR=~/Pictures/Portfolio

# Server port for review UI
PORT=3000

# Contentful locale for all field values (default: en-US)
# CONTENTFUL_LOCALE=en-US

# Contentful content type IDs (defaults match the setup script)
# PHOTO_CONTENT_TYPE=photo
# COLLECTION_CONTENT_TYPE=collection

# Claude model for vision analysis
# VISION_MODEL=claude-sonnet-4-6

# File write stability threshold in ms (how long to wait after last
# write event before treating a file as complete)
# WRITE_STABILITY_THRESHOLD=3000
