{
  "name": "portfolio-tools",
  "version": "0.1.0",
  "description": "Photo metadata automation — AI vision + EXIF extraction + Contentful publishing with local review UI",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts dev",
    "analyze": "tsx src/cli.ts analyze",
    "watch": "tsx src/cli.ts watch",
    "publish": "tsx src/cli.ts publish",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check . && eslint src/ && tsc --noEmit",
    "setup": "tsx src/setup.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@clack/prompts": "^1.2.0",
    "@hono/node-server": "^2.0.0",
    "chokidar": "^5.0.0",
    "contentful-management": "^12.3.1",
    "dotenv": "^17.4.2",
    "exifr": "^7.1.3",
    "hono": "^4.7.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
